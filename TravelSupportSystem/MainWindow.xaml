<Window x:Class="TravelSupportSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Travel Support System"
        Height="640" Width="360"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F5F5F5">

        <StackPanel Margin="15">

            <TextBlock Text="Da Nang Travel"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,15"/>

            <TextBlock Text="Budget (VND)"/>
            <TextBox Height="40"
                     Margin="0,5,0,10"
                     Text="{Binding Budget}"/>

            <TextBlock Text="Days"/>
            <TextBox Height="40"
                     Margin="0,5,0,10"
                     Text="{Binding Days}"/>

            <Button Content="Generate Plan"
                    Height="45"
                    Background="#2196F3"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="BtnGenerate_Click"/>

            <TextBlock Text="Result"
                       Margin="0,15,0,5"
                       FontWeight="Bold"/>

            <TextBox Height="250"
                     Text="{Binding Result}"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

    </Grid>
</Window>