<Window x:Class="TravelSupportSystem.DangNhap"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        Height="640" Width="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#2196F3">
        <Border Background="White"
                CornerRadius="25"
                VerticalAlignment="Center"
                Margin="20">

            <StackPanel Margin="25">

                <TextBlock Text="Travel Support System"
                           FontSize="22"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,30"/>

                <!-- Username -->
                <TextBlock Text="Username"/>
                <TextBox x:Name="txtUser"
                         Height="45"
                         FontSize="14"
                         Margin="0,5,0,10"/>

                <!-- Password -->
                <TextBlock Text="Password"/>
                <PasswordBox x:Name="txtPass"
                             Height="45"
                             FontSize="14"
                             Margin="0,5,0,10"/>

                <!-- Login button -->
                <Button Content="LOGIN"
                        Height="45"
                        Margin="0,20,0,0"
                        Background="#2196F3"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnLogin_Click"/>

                <TextBlock Text="Demo: admin / 123"
                           FontSize="12"
                           Foreground="Gray"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"/>
            </StackPanel>

        </Border>
    </Grid>
</Window>
