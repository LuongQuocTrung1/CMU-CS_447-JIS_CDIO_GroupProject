<Window x:Class="TravelSupportSystem.Views.DangKy"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng Ký Tài Khoản" Height="640" Width="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="#2196F3">
        <Border Background="White"
            CornerRadius="25"
            VerticalAlignment="Center"
            Margin="20">

            <StackPanel Margin="25">

                <TextBlock Text="Tạo Tài Khoản Mới"
                       FontSize="22"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,20"/>

                <TextBlock Text="Username mới"/>
                <TextBox x:Name="txtNewUser"
                     Height="45"
                     FontSize="14"
                     Margin="0,5,0,10"/>

                <TextBlock Text="Password"/>
                <PasswordBox x:Name="txtNewPass"
                         Height="45"
                         FontSize="14"
                         Margin="0,5,0,10"/>

                <TextBlock Text="Xác nhận Password"/>
                <PasswordBox x:Name="txtConfirmPass"
                         Height="45"
                         FontSize="14"
                         Margin="0,5,0,10"/>

                <Button Content="TẠO TÀI KHOẢN"
                    Height="45"
                    Margin="0,20,0,0"
                    Background="#2196F3"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="BtnCreateAccount_Click"/>

                <Button Content="QUAY LẠI ĐĂNG NHẬP"
                    Height="45"
                    Margin="0,10,0,0"
                    Background="Transparent"
                    Foreground="Gray"
                    BorderThickness="0"
                    FontWeight="Bold"
                    Click="BtnBackToLogin_Click"/>
            </StackPanel>

        </Border>
    </Grid>
</Window>