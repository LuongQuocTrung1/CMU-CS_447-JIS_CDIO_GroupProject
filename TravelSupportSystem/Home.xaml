<Window x:Class="TravelSupportSystem.Home"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Home"
        Height="640" Width="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#2196F3">

        <StackPanel Margin="20">

            <TextBlock Text="Da Nang Travel Assistant"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,30,0,40"/>

            <Button Content="🗺  Travel Planner"
                    Height="55"
                    FontSize="14"
                    Margin="0,10"
                    Click="BtnPlanner_Click"/>

            <Button Content="📍  Open Google Maps"
                    Height="55"
                    FontSize="14"
                    Margin="0,10"
                    Click="BtnMap_Click"/>

            <Button Content="❌  Logout"
                    Height="55"
                    FontSize="14"
                    Margin="0,10"
                    Click="BtnLogout_Click"/>

        </StackPanel>

    </Grid>
</Window>
